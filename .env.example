# Session encryption secret. Use at least 32 random chars in production.
NEXUS_SESSION_SECRET="change-me-use-a-long-random-secret-with-32-plus-chars"

# Nexus API base. The classic API base is below. Keep configurable because the docs may expose newer endpoints.
NEXUS_API_BASE="https://api.nexusmods.com/v1"
NEXUS_API_V3_BASE="https://api.nexusmods.com/v3"

# When true, the app works without a Nexus key using sample data. Useful for UI development.
NEXUS_MOCK_MODE="true"
NEXUS_COLLECTION_SCHEMA_ID="1"
NEXUS_COLLECTION_CATEGORY_ID=""

# Text search endpoint template, only needed if your Nexus docs expose a specific search route.
# Supported placeholders: {base}, {game}, {q}, {page}, {sort}, {category}
# Example format only; set this according to the current Nexus docs if different:
NEXUS_SEARCH_URL_TEMPLATE=""

# Optional endpoint for "Minhas collections". The bundled OpenAPI does not expose a list route.
# Supported placeholder: {base}
NEXUS_COLLECTIONS_LIST_URL_TEMPLATE=""

# Collection publish endpoint templates. Keep these configured from the current Nexus OpenAPI docs.
# The app can generate a manifest now; publish adapter is isolated in lib/nexus-collections.ts.
NEXUS_UPLOAD_SESSION_URL_TEMPLATE=""
NEXUS_UPLOAD_FINALIZE_URL_TEMPLATE=""
NEXUS_COLLECTION_CREATE_URL_TEMPLATE=""
NEXUS_COLLECTION_REVISION_URL_TEMPLATE=""
NEXUS_COLLECTION_PUBLISH_URL_TEMPLATE=""
